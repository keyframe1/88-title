# 88 Title — environment variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must NEVER be committed.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# ----------------------------------------------------------------------------
# Supabase (auth + Postgres + realtime) — used now (client setup) and later
# ----------------------------------------------------------------------------
# Project URL and anon key are safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"

# Service role key — SERVER ONLY. Bypasses Row Level Security. Never expose.
# (Not used yet; needed once we wire the check-in queue / dealer portal.)
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# ----------------------------------------------------------------------------
# Site
# ----------------------------------------------------------------------------
# Canonical base URL, used for absolute links / metadata.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Stripe — LATER PHASE (no charging is built yet). Listed for reference only.
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ----------------------------------------------------------------------------
# Resend — LATER PHASE (transactional email). Listed for reference only.
# ----------------------------------------------------------------------------
# RESEND_API_KEY="re_..."
