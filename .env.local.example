# 88 Title — environment variables
#
# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored and must NEVER be committed.
# Only variables prefixed with NEXT_PUBLIC_ are exposed to the browser.

# ----------------------------------------------------------------------------
# Supabase (auth + Postgres + realtime) — used now (client setup) and later
# ----------------------------------------------------------------------------
# Project URL and publishable/anon key are browser-safe. The newer publishable
# key (sb_publishable_...) is the value for NEXT_PUBLIC_SUPABASE_ANON_KEY.
NEXT_PUBLIC_SUPABASE_URL="https://your-project-ref.supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-publishable-or-anon-key"

# Secret key (new "sb_secret_" format). SERVER ONLY: bypasses Row Level Security,
# never expose to the browser. The web app never loads this; it is used ONLY by
# the local provisioning script (scripts/create-dealer.mjs) to create dealer and
# staff logins. Keep it out of NEXT_PUBLIC_* and out of client code.
SUPABASE_SECRET_KEY="your-secret-key"

# ----------------------------------------------------------------------------
# Site
# ----------------------------------------------------------------------------
# Canonical base URL, used for absolute links / metadata, and for the dealer
# password-reset redirect target and links inside notification emails. Set this
# to the real domain in production.
NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# ----------------------------------------------------------------------------
# Stripe — LATER PHASE (no charging is built yet). Listed for reference only.
# ----------------------------------------------------------------------------
# NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."
# STRIPE_SECRET_KEY="sk_test_..."
# STRIPE_WEBHOOK_SECRET="whsec_..."

# ----------------------------------------------------------------------------
# Resend — dealer transaction notification emails (server only).
# ----------------------------------------------------------------------------
# Emails customers (check-in confirmation + "you're up") and dealers (ready for
# pickup + attention). BOTH vars are required to send; if either is unset the
# app runs fine and email sending is skipped (a warning is logged). To activate:
#   1. Add your Resend API key below.
#   2. Set RESEND_FROM to a verified sender (single source of truth for the From
#      address). Until a domain is verified in Resend, the shared
#      "onboarding@resend.dev" address works for testing.
# RESEND_API_KEY="re_..."
# RESEND_FROM="88 Title <notifications@your-verified-domain.com>"

# ----------------------------------------------------------------------------
# Web Push — check-in queue "you're up" notifications (the SMS alternative).
# ----------------------------------------------------------------------------
# Generate a key pair with: node scripts/generate-vapid.mjs
# If these are unset, the app runs fine and push is skipped (email + the live
# status page still work). The PRIVATE key is server-only; the PUBLIC key is
# shipped to the browser (NEXT_PUBLIC_) as the applicationServerKey.
# VAPID_PUBLIC_KEY="B..."            # raw base64url P-256 point (65 bytes)
# VAPID_PRIVATE_KEY="..."            # raw base64url P-256 scalar (32 bytes) — SECRET
# VAPID_SUBJECT="mailto:ops@88title.com"   # mailto: or https: contact for push services
# NEXT_PUBLIC_VAPID_PUBLIC_KEY="B..."      # same value as VAPID_PUBLIC_KEY, exposed to the browser
